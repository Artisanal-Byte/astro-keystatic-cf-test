# Astro
ASTRO_HOST=localhost
ASTRO_PORT=4321

# Cloudflare Pages / runtime
PUBLIC_ENV=preview

# Keystatic GitHub reader (Test 2) — fine-grained PAT, contents:read scope.
# Create at: https://github.com/settings/personal-access-tokens/new
GITHUB_REPO_OWNER=your-org
GITHUB_REPO_NAME=test-content-repo
GITHUB_CONTENT_READ_TOKEN=github_pat_xxxx

# D1 (Test 3) — populated from `wrangler d1 list` / dashboard.
D1_DATABASE_ID=xxxx-xxxx-xxxx
D1_DATABASE_NAME=test-db
